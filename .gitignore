# Python virtual environments (platform-specific — never commit these)
.venv/
venv/
env/

# Vendored dependencies installed by vendor-setup.bat (machine/version-specific)
deps/

# Python bytecode / caches
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/

# Copilot CLI local auth / config (do not publish credentials)
.copilot/

# Local env file (may hold proxy credentials / tokens) — never commit
.env
*.env
!example.env

# OS / editor cruft
.DS_Store
Thumbs.db
*.swp
.idea/
.vscode/
